# Contact Form SMTP Configuration
# Copy this file to .env and configure the fields below for real email dispatching.

# The SMTP host (e.g. smtp.gmail.com, smtp.mailgun.org, smtp.sendgrid.net, etc.)
SMTP_HOST=your-smtp-host.example.com

# SMTP port (usually 587 for TLS, or 465 for SSL)
SMTP_PORT=587

# Enable TLS or SSL (set to true for 465 SSL, false for others)
SMTP_SECURE=false

# SMTP Auth credentials
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password

# Recipient email address (who receives the portfolio messages). 
# If left blank, it will default to SMTP_USER.
CONTACT_EMAIL_RECEIVER=receiver-email@example.com
